# Copia este archivo a .env.local: cp env.example .env.local
# Luego edita .env.local con tus valores reales.

# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:password@localhost:5432/catalogo_inmobiliario?schema=public"

# NextAuth (obligatorios)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera-una-clave-secreta-aleatoria-aqui"

# OAuth Google (opcional)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Token para crear primer admin (opcional)
# ADMIN_CREATE_TOKEN="create-admin-2024"
